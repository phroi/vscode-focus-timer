{
  "name": "focus-timer",
  "displayName": "Focus Timer",
  "description": "Track VS Code focused time",
  "publisher": "phroi",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/phroi/vscode-focus-timer.git"
  },
  "extensionKind": [
    "workspace"
  ],
  "engines": {
    "vscode": "^1.109.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {},
  "scripts": {
    "package": "pnpm install && pnpm build",
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "eslint .",
    "check": "pnpm clean:deep && pnpm install && pnpm lint && pnpm build",
    "check:fresh": "rm pnpm-lock.yaml && pnpm run check",
    "check:ci": "CI=true pnpm run check",
    "check:full": "pnpm check:fresh && pnpm check:ci",
    "clean": "rm -rf dist",
    "clean:deep": "pnpm clean && rm -rf node_modules",
    "coworker": "ln -sf AGENTS.md CLAUDE.md && claude --model opus --dangerously-skip-permissions"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.47",
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.109.0",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937"
}
